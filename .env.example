# Application
NODE_ENV=development
PORT=3000

# Frontend
FRONTEND_URL=http://localhost:5173
COOKIE_DOMAIN=localhost

# Database
DB_HOST=localhost
DB_PORT=5434
DB_USERNAME=root
DB_PASSWORD=root
DB_DATABASE=bunker
DB_SYNCHRONIZE=false
DB_RUN_MIGRATIONS=true
DB_LOGGING=true
DB_DISABLE_SSL_AUTH=true

# Auth (HS256 JWT carried in HttpOnly cookie)
JWT_SECRET=replace_me_with_random_64_chars
JWT_EXPIRE=30d
COOKIE_NAME=bunker_session

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Sentry
SENTRY_DSN=
SENTRY_ENABLE=false

# Deployment notes (Vercel):
# - Set every variable above in Project Settings → Environment Variables for
#   each target (Production / Preview / Development). The app validates env on
#   boot via `validateEnvs` and crashes the cold-start if anything is missing.
# - `PORT` is ignored on Vercel (the platform owns the HTTP server) but the
#   zod schema still requires it — set it to any number (e.g. 3000).
# - `FRONTEND_URL` must match the Vercel FE origin so CORS allows credentials.
# - `GOOGLE_CALLBACK_URL` must be the Vercel BE origin + `/api/auth/google/callback`
#   and the same URL must be whitelisted in the Google OAuth client.
# - Use a pooled Postgres connection string (e.g. Supabase/Neon pooler) — each
#   warm worker holds its own pool, so an unpooled DB will run out of slots.
# - `DB_RUN_MIGRATIONS=true` will run migrations on every cold start; it's a
#   no-op once applied, but adds a few hundred ms. Flip to `false` and run
#   `pnpm migration:run` manually if you'd rather control timing.
