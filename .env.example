# Application
NODE_ENV=development
PORT=3000

# Frontend
FRONTEND_URL=http://localhost:5173
COOKIE_DOMAIN=localhost

# Database
DB_HOST=localhost
DB_PORT=5434
DB_USERNAME=root
DB_PASSWORD=root
DB_DATABASE=bunker
DB_SYNCHRONIZE=false
DB_RUN_MIGRATIONS=true
DB_LOGGING=true
DB_DISABLE_SSL_AUTH=true

# Auth (HS256 JWT carried in HttpOnly cookie)
JWT_SECRET=replace_me_with_random_64_chars
JWT_EXPIRE=30d
COOKIE_NAME=bunker_session

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Sentry
SENTRY_DSN=
SENTRY_ENABLE=false
